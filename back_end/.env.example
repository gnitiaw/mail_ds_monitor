# App
APP_NAME=mail-ds-monitor
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# Security
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=mail_ds_monitor
MYSQL_USER=mail_ds_user
MYSQL_PASSWORD=MailDsMonitor#2026!Secure
MYSQL_CHARSET=utf8mb4
DB_ECHO=false
DB_POOL_PRE_PING=true
DB_AUTO_CREATE_TABLES=false

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173

# Mail Pull
MAIL_PULL_ENABLED=true
MAIL_PULL_DEFAULT_FOLDER=INBOX
MAIL_PULL_BATCH_SIZE=50
MAIL_PULL_TIMEOUT_SECONDS=60
MAIL_PULL_RETRY_TIMES=2
MAIL_PARSE_ATTACHMENTS=false

# AI Extraction Agent
LLM_ENABLED=true
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-llm-api-key
LLM_MODEL=replace-with-model-name
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_EXTRACTION_PROMPT_VERSION=v1
LLM_SUMMARY_PROMPT_VERSION=v1

# Daily Summary Mail
SUMMARY_ENABLED=true
SUMMARY_SCHEDULE_TYPE=daily
SUMMARY_DAILY_SEND_TIME=09:00
SUMMARY_TIMEZONE=Asia/Shanghai
SUMMARY_EMPTY_RESULT_POLICY=skip
SUMMARY_USE_AI=true

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Mail DS Monitor
SMTP_TIMEOUT_SECONDS=30

# Observability
ENABLE_AUDIT_LOG=true
ENABLE_TASK_LOG=true

# Notes
# Mailbox accounts are expected to be managed in the application database.
# This file stores only global runtime configuration.
